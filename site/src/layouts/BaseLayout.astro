---
import '../styles/global.css';
import SocialLinks from '../components/SocialLinks.astro';
import { logo } from '../site';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title.includes('BATTE') ? title : `${title} · BATTE Interioristas`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="min-h-dvh bg-stone-100 text-stone-900 antialiased">
    <a
      href="#contenido"
      class="focus:bg-stone-900 focus:text-white focus:outline-none sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:px-3 focus:py-2"
      >Ir al contenido</a
    >
    <header class="relative z-50 border-b border-stone-200 bg-stone-200/80 backdrop-blur-sm">
      <div class="mx-auto max-w-6xl px-6 py-4 md:py-5">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="inline-flex shrink-0 items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2">
            <img
              src={logo.src}
              alt={logo.alt}
              width={logo.width}
              height={logo.height}
              class="h-9 w-auto md:h-10"
              decoding="async"
            />
          </a>
          <button
            id="menu-toggle"
            type="button"
            aria-controls="mobile-menu"
            aria-expanded="false"
            class="inline-flex items-center justify-center border border-stone-300 bg-white p-2 text-stone-800 hover:bg-stone-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 md:hidden"
          >
            <span id="menu-toggle-label" class="sr-only">Abrir menú principal</span>
            <svg id="icon-menu-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg id="icon-menu-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div id="mobile-menu" class="hidden border-t border-stone-200/80 bg-stone-200/95 pt-4 pb-2 md:hidden">
          <nav aria-label="Principal móvil" class="flex flex-col gap-3 px-0 pb-2 text-sm text-stone-800">
            <a href="/" class="hover:text-stone-950 hover:underline">Inicio</a>
            <a href="/servicios" class="hover:text-stone-950 hover:underline">Servicios</a>
            <a href="/proyectos" class="hover:text-stone-950 hover:underline">Proyectos</a>
            <a href="/prensa" class="hover:text-stone-950 hover:underline">Prensa</a>
            <a href="/estudio" class="hover:text-stone-950 hover:underline">Estudio</a>
            <a href="/contacto" class="hover:text-stone-950 hover:underline">Contacto</a>
          </nav>
        </div>
        <div class="mt-4 hidden items-center justify-end gap-x-8 gap-y-3 md:flex">
          <nav aria-label="Principal" class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-stone-800">
            <a href="/" class="hover:text-stone-950 hover:underline">Inicio</a>
            <a href="/servicios" class="hover:text-stone-950 hover:underline">Servicios</a>
            <a href="/proyectos" class="hover:text-stone-950 hover:underline">Proyectos</a>
            <a href="/prensa" class="hover:text-stone-950 hover:underline">Prensa</a>
            <a href="/estudio" class="hover:text-stone-950 hover:underline">Estudio</a>
            <a href="/contacto" class="hover:text-stone-950 hover:underline">Contacto</a>
          </nav>
          <SocialLinks class="border-stone-300 md:border-l md:pl-6" />
        </div>
      </div>
    </header>
    <div
      id="mobile-backdrop"
      class="fixed inset-0 z-40 hidden bg-stone-900/30 md:hidden"
      aria-hidden="true"
    >
    </div>
    <main id="contenido">
      <slot />
    </main>
    <footer class="mt-20 border-t border-stone-200 bg-white">
      <div class="mx-auto max-w-6xl px-6 py-12 text-sm text-stone-600">
        <a href="/" class="inline-block focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2">
          <img
            src={logo.src}
            alt={logo.alt}
            width={logo.width}
            height={logo.height}
            class="h-8 w-auto opacity-95 md:h-9"
            decoding="async"
          />
        </a>
        <address class="mt-4 not-italic leading-relaxed">
          Ramón Miquel i Planas, 17<br />
          08034 Barcelona<br />
          <a href="tel:+34932098112" class="hover:text-stone-900">+34 932 098 112</a><br />
          <a href="mailto:info@batteinterioristas.com" class="hover:text-stone-900">info@batteinterioristas.com</a>
        </address>
        <div class="mt-6">
          <p class="text-xs font-medium uppercase tracking-wide text-stone-500">Redes</p>
          <SocialLinks class="mt-2" />
        </div>
        <p class="mt-6 text-xs text-stone-500">Especificación del sitio: carpeta <code class="rounded bg-stone-100 px-1">docs/</code> en el repositorio.</p>
      </div>
    </footer>
    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const backdrop = document.getElementById('mobile-backdrop');
      const iconOpen = document.getElementById('icon-menu-open');
      const iconClose = document.getElementById('icon-menu-close');
      const label = document.getElementById('menu-toggle-label');

      function setMenuOpen(open) {
        if (!toggle || !menu) return;
        menu.classList.toggle('hidden', !open);
        toggle.setAttribute('aria-expanded', String(open));
        if (backdrop) backdrop.classList.toggle('hidden', !open);
        if (iconOpen) iconOpen.classList.toggle('hidden', open);
        if (iconClose) iconClose.classList.toggle('hidden', !open);
        if (label) label.textContent = open ? 'Cerrar menú principal' : 'Abrir menú principal';
        document.body.style.overflow = open ? 'hidden' : '';
      }

      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          const willOpen = menu.classList.contains('hidden');
          setMenuOpen(willOpen);
        });
      }

      if (backdrop) {
        backdrop.addEventListener('click', () => setMenuOpen(false));
      }

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setMenuOpen(false));
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
          setMenuOpen(false);
          toggle?.focus();
        }
      });

      window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
        if (e.matches) setMenuOpen(false);
      });
    </script>
  </body>
</html>
