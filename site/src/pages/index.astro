---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const proyectos = await getCollection('proyectos');
const destacados = proyectos.slice(0, 3);
---

<BaseLayout
  title="BATTE Interioristas · Proyectos de interiorismo en Barcelona"
  description="Estudio de interiorismo en Barcelona especializado en proyectos residenciales y comerciales. Reformas integrales, decoración de interiores y diseño a medida en Barcelona y alrededores."
>
  <section class="border-b border-stone-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <h1 class="text-3xl font-medium tracking-tight text-stone-900 md:text-4xl">BATTE Interioristas</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-600">
        Estudio de interiorismo en Barcelona especializado en viviendas, espacios comerciales y proyectos integrales con una mirada contemporánea, funcional y atemporal.
      </p>
      <p class="mt-4 max-w-2xl leading-relaxed text-stone-600">
        BATTE Interioristas desarrolla proyectos de reforma, interiorismo y decoración cuidando la arquitectura existente, la luz, los materiales y la forma de vivir cada espacio.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-xl font-medium text-stone-900">Proyectos destacados</h2>
      <p class="mt-2 max-w-2xl text-stone-600">
        Una selección de proyectos residenciales y comerciales en Barcelona, Maresme, Girona y La Cerdanya.
      </p>
      <ul class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          destacados.map((p) => (
            <li>
              <a href={`/proyectos/${p.id}/`} class="group block">
                <div class="aspect-[4/3] overflow-hidden bg-stone-200">
                  <img
                    src={p.data.cover}
                    alt={p.data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                    width="800"
                    height="600"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-4 font-medium text-stone-900 group-hover:underline">{p.data.title}</h3>
                <p class="mt-1 text-sm text-stone-500">{p.data.location}{p.data.year ? ` · ${p.data.year}` : ''}</p>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-10">
        <a href="/proyectos" class="text-sm font-medium text-stone-900 underline decoration-stone-300 underline-offset-4 hover:decoration-stone-900"> Ver todos los proyectos </a>
      </p>
    </div>
  </section>

  <section class="border-t border-stone-200 bg-stone-50 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-xl font-medium text-stone-900">Enfoque</h2>
      <p class="mt-4 max-w-2xl leading-relaxed text-stone-600">
        Cada proyecto se trabaja de forma personalizada, combinando diseño, gestión y dirección de obra para acompañar al cliente durante todo el proceso.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <p class="text-lg text-stone-700">¿Tienes un espacio que transformar?</p>
      <a
        href="/contacto"
        class="mt-6 inline-block border border-stone-900 bg-stone-900 px-8 py-3 text-sm font-medium text-white hover:bg-stone-800"
      >
        Contacto
      </a>
    </div>
  </section>
</BaseLayout>
