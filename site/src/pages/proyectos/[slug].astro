---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((p) => ({
    params: { slug: p.id },
    props: { proyecto: p },
  }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const gallery = proyecto.data.gallery ?? [];
---

<BaseLayout title={proyecto.data.title} description={`${proyecto.data.title} — ${proyecto.data.location}. Proyecto de BATTE Interioristas.`}>
  <article class="mx-auto max-w-4xl px-6 py-12">
    <nav class="text-sm text-stone-500" aria-label="Migas de pan">
      <a href="/proyectos" class="hover:text-stone-900 hover:underline">Proyectos</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-800">{proyecto.data.title}</span>
    </nav>

    <header class="mt-8">
      <h1 class="text-3xl font-medium tracking-tight text-stone-900 md:text-4xl">{proyecto.data.title}</h1>
      <p class="mt-3 text-stone-600">
        {proyecto.data.location}
        {proyecto.data.year ? ` · ${proyecto.data.year}` : ''}
      </p>
    </header>

    <div class="mt-10 aspect-[16/10] overflow-hidden bg-stone-200">
      <img
        src={proyecto.data.cover}
        alt={proyecto.data.title}
        class="h-full w-full object-cover"
        width="1600"
        height="1000"
        fetchpriority="high"
      />
    </div>

    <div class="markdown-body mt-12 space-y-4 leading-relaxed text-stone-600 [&_h2]:mt-10 [&_h2]:text-lg [&_h2]:font-medium [&_h2]:text-stone-900">
      <Content />
    </div>

    {
      gallery.length > 0 && (
        <section class="mt-16" aria-labelledby="galeria-heading">
          <h2 id="galeria-heading" class="text-lg font-medium text-stone-900">
            Galería
          </h2>
          <p class="mt-2 text-sm text-stone-500">
            Lightbox pendiente de librería (ver <code class="rounded bg-stone-100 px-1 text-xs">docs/SPEC.md</code>). Vista en cuadrícula.
          </p>
          <ul class="mt-8 grid gap-4 sm:grid-cols-2">
            {gallery.map((src, i) => (
              <li class="overflow-hidden bg-stone-200">
                <img
                  src={src}
                  alt={`${proyecto.data.title} — imagen ${i + 1}`}
                  class="aspect-[4/3] w-full object-cover"
                  width="800"
                  height="600"
                  loading="lazy"
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="mt-16">
      <a href="/proyectos" class="font-medium text-stone-900 underline decoration-stone-300 underline-offset-4 hover:decoration-stone-900">← Volver a proyectos</a>
    </p>
  </article>
</BaseLayout>
